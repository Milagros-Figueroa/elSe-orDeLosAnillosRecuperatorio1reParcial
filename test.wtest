import territorios.*
import seres.*


describe "Bienvenido al mundo del señor de los anillos" {
    const bosque = new Territorio()
    const elfoSilvano1 = new ElfoSilvano()
    const hobbit1 = new Hobbit()
    const enanoHerrero1 = new EnanoHerrero()
    
  method initialize(){
    bosque.agregarSeres(enanoHerrero1)
    bosque.agregarSeres(elfoSilvano1)
    bosque.agregarSeres(hobbit1)
    hobbit1.organizarUnaFiesta()
  }
  
  
  test "la habilidad del elfo debe ser 580" {
    assert.equals(580, elfoSilvano1.habilidad())
  }
  test "la habilidad del hobbit 1100" {
    assert.equals(1100, hobbit1.habilidad())
  }

  test "y la habilidad del enano 300 respectivamente." {
    assert.equals(300, enanoHerrero1.habilidad())
  }

  test "el hobbit debe tener 45 amigos y debe ser inmortal." {
    assert.equals(45, hobbit1.cantAmigos())
   
  }
  test "el hobbit tiene 45 amigos, por ende, es inmortal" {
     assert.that(hobbit1.esInmortal())
  }

test "el valor máximo de habilidad entre todos los seres inmortales debe ser 1100. " {
  assert.equals(660, bosque.promedioDeHabilidadTotal())
}

test "los seres torpes del territorio son el elfo y el enano." {
  assert.equals([enanoHerrero1, elfoSilvano1], bosque.seresTorpes())
}

test "existe un ser mortal en el territorio."{
   assert.that(bosque.hayMortalesEnTerritorio())
}
}